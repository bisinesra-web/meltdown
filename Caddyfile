localhost {
    # Socket.IO — WebSocket + long-polling with immediate flush
    reverse_proxy /socket.io/* backend:3000 {
        flush_interval -1
    }

    # GET /game exactly → frontend SPA
    @gameExact {
        method GET
        path /game
    }
    reverse_proxy @gameExact frontend:80

    # REST API
    reverse_proxy /rooms* backend:3000
    reverse_proxy /game*  backend:3000

    # Frontend SPA
    reverse_proxy * frontend:80
}
